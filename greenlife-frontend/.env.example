# GreenLife Frontend Environment Configuration Example
# Copy this file to .env in production or local environments

# Base URL for the GreenLife backend APIs
VITE_API_BASE_URL=

# Default timeout for API requests in milliseconds (defaults to 15000)
VITE_API_TIMEOUT=15000

# Google OAuth Client ID for login integration
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

